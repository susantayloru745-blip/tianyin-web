# 依赖库（最占空间，绝对不要上传）
node_modules/
jspm_packages/

# 构建产物（代码编译后的结果，由服务器自动生成）
dist/
build/
.next/
out/
bin/
obj/

# 环境配置文件（包含 API 密钥、数据库密码等敏感信息，严禁上传！）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# 操作系统临时文件（苹果或 Windows 自动生成的杂物）
.DS_Store
Thumbs.db

# 编辑器私有配置（如 VS Code 的本地设置）
.vscode/
.idea/
*.swp